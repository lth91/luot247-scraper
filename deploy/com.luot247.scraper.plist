<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.luot247.scraper</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/opbot/.openclaw/skills/luot247-scraper/deploy/run.sh</string>
    </array>

    <!-- Chạy mỗi giờ ở phút thứ 20 (giữa cron crawl-electricity-news ở phút 0 và discovery-rss-news ở phút 30) -->
    <!-- Giờ VN 7h-22h tương ứng UTC 0-15. Mac Mini chạy ở local timezone (TZ env) — nếu Mac Mini set Asia/Ho_Chi_Minh thì list này là 7-22 VN. -->
    <key>StartCalendarInterval</key>
    <array>
        <dict><key>Hour</key><integer>7</integer><key>Minute</key><integer>20</integer></dict>
        <dict><key>Hour</key><integer>8</integer><key>Minute</key><integer>20</integer></dict>
